PORT=8000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-secret
COOKIE_EXPIRE=7
# Use COOKIE_SECURE=true on Vercel/HTTPS.
COOKIE_SECURE=false
# Add your deployed frontend origin here for CORS and origin checks.
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
# Vercel Cron sends Authorization: Bearer CRON_SECRET when this env var exists.
CRON_SECRET=replace-with-a-long-random-secret-for-vercel-cron
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

MONGODB_URL=mongodb://127.0.0.1:27017/primebid
AI_FEATURES_ENABLED=true
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=
